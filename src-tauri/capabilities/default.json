{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "log-*"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:event:default",
    "updater:default",
    "process:allow-restart",
    "process:default",
    "dialog:default"
  ]
}