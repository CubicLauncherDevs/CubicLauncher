{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "CubicLauncher",
	"version": "27.0.1",
	"identifier": "com.cubiclauncher.launcher",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "CubicLauncher @27",
				"width": 800,
				"height": 600,
				"minWidth": 800,
				"minHeight": 600
			}
		],
		"security": {
			"csp": {
				"default-src": [
					"'self'",
					"tauri:",
					"http://localhost:*",
					"https://tauri.localhost"
				],
				"img-src": [
					"'self'",
					"asset:",
					"https://asset.localhost",
					"https://minotar.net",
					"https://cdn.modrinth.com",
					"https://media.forgecdn.net",
					"https://apps.modpacks.ch/modpacks/art/",
					"http://localhost:*",
					"data:"
				],
				"style-src": [
					"'self'",
					"'unsafe-inline'",
					"http://localhost:*",
					"https://tauri.localhost"
				],
				"font-src": ["'self'", "http://localhost:*"],
				"script-src": [
					"'self'",
					"'unsafe-inline'",
					"http://localhost:*"
				],
				"connect-src": [
					"'self'",
					"tauri://localhost",
					"ipc://localhost",
					"http://localhost:*",
					"https://tauri.localhost",
					"https://minotar.net",
					"https://api.modrinth.com",
					"https://api.curseforge.com",
					"https://api.modpacks.ch/public/modpack"
				]
			},
			"devCsp": {
				"default-src": [
					"'self'",
					"tauri:",
					"http://localhost:*",
					"https://tauri.localhost"
				],
				"img-src": [
					"'self'",
					"asset:",
					"https://asset.localhost",
					"https://minotar.net",
					"https://cdn.modrinth.com",
					"https://media.forgecdn.net",
					"https://apps.modpacks.ch/modpacks/art/",
					"http://localhost:*",
					"data:"
				],
				"style-src": [
					"'self'",
					"'unsafe-inline'",
					"http://localhost:*",
					"https://tauri.localhost"
				],
				"font-src": ["'self'", "http://localhost:*"],
				"script-src": [
					"'self'",
					"'unsafe-inline'",
					"http://localhost:*"
				],
				"connect-src": [
					"'self'",
					"tauri://localhost",
					"ipc://localhost",
					"http://localhost:*",
					"https://tauri.localhost",
					"https://minotar.net",
					"https://api.modrinth.com",
					"https://api.curseforge.com",
					"https://api.modpacks.ch/public/modpack"
				]
			},
			"assetProtocol": {
				"enable": true,
				"scope": ["$HOME/.cubic/**"]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"createUpdaterArtifacts": true,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGN0YxODA4NUU5QzVENDQKUldSRVhaeGVDQmgvTCtrbitjYmljOGV4dDZDdUV1bXQ5WVpQWWpEcm9ucTk5YU9iTkxYSDJxdnIK",
			"endpoints": [
				"https://github.com/CubicLauncher/CubicLauncher/releases/latest/download/latest.json"
			],
			"windows": { "installMode": "passive" }
		}
	}
}
