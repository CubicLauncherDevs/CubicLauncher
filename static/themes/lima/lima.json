{
  "name": "Lima",
  "author": "CubicLauncher",
  "version": "1.0",
  "type": "builtin",
  "bg_image": "/themes/lima/lima.webp",
  "bg_image_blur": "5px",
  "bg_image_opacity": 0.7,
  "variables": {
    "--bg-main": "#0a0f0a",
    "--bg-sidebar": "#0c110c",
    "--bg-card": "#121a12",
    "--bg-item-active": "#162016",
    "--bg-overlay": "rgba(0,10,0,0.75)",
    "--bg-input": "#161e16",

    "--bg-sidebar-gradient": "linear-gradient(180deg, #0c110c 0%, #0a0f0a 100%)",
    "--bg-card-gradient": "linear-gradient(135deg, rgba(151,196,89,0.04) 0%, rgba(151,196,89,0) 100%)",

    "--text-primary": "#c8ddb0",
    "--text-secondary": "#5a7a5a",
    "--text-muted": "#3a4e3a",
    "--border": "#1a2e1a",
    "--border-color": "#1a2e1a",
    "--border-width": "1px",
    "--border-radius": "8px",
    "--border-radius-sm": "4px",
    "--border-radius-lg": "12px",
    "--accent": "#97C459",
    "--accent-rgb": "151,196,89",
    "--accent-hover": "#a8d06a",
    "--accent-text": "#0a1a04",
    "--accent-primary": "#97C459",
    "--shadow-sm": "0 1px 3px rgba(0,0,0,0.5)",
    "--shadow-md": "0 4px 12px rgba(0,0,0,0.6)",
    "--shadow-lg": "0 8px 28px rgba(0,0,0,0.7)",
    "--glow-accent": "0 0 12px rgba(151,196,89,0.2)",
    "--glow-error": "0 0 12px rgba(248,81,73,0.3)",
    "--glow-success": "0 0 12px rgba(151,196,89,0.3)",
    "--color-success": "#97C459",
    "--color-success-rgb": "151,196,89",
    "--color-error": "#f85149",
    "--color-error-rgb": "248,81,73",
    "--color-warning": "#d29922",
    "--color-warning-rgb": "210,153,34",
    "--color-status-starting": "#5e81ac",
    "--color-status-started": "#97C459",
    "--icon-filter": "invert(0.8) sepia(1) saturate(0.5) hue-rotate(60deg)",
    "--icon-filter-error": "invert(16%) sepia(89%) saturate(4668%) hue-rotate(0deg) brightness(96%) contrast(112%)",

    "--clr-loader-vanilla": "#78909c",
    "--clr-loader-fabric": "#66bb6a",
    "--clr-loader-forge": "#ffa726",
    "--clr-loader-quilt": "#ab47bc",

    "--sidebar-width": "260px",

    "--scrollbar-track": "#0a0f0a",
    "--scrollbar-thumb": "#1a2e1a",
    "--font-family": "Cantarell, sans-serif",
    "--font-size-base": "14px",
    "--font-size-sm": "12px",
    "--font-size-lg": "16px"
  }
}
