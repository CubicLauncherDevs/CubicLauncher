{
  "name": "Oscuro",
  "author": "CubicLauncher",
  "version": "1.0",
  "type": "builtin",
  "bg_image": "/themes/dark/dark.webp",
  "bg_image_blur": "10px",
  "bg_image_opacity": 0.5,
  "variables": {
    "--bg-main": "#0c0c0c",
    "--bg-sidebar": "#0f1010",
    "--bg-card": "#16161a",
    "--bg-item-active": "#1c1d1d",
    "--bg-overlay": "rgba(0,0,0,0.7)",
    "--bg-input": "#1c1c1c",

    "--bg-sidebar-gradient": "linear-gradient(180deg, #0f1010 0%, #0c0c0c 100%)",
    "--bg-card-gradient": "linear-gradient(135deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0) 100%)",

    "--text-primary": "#d8d8d8",
    "--text-secondary": "#606060",
    "--text-muted": "#444444",

    "--border": "#242424",
    "--border-color": "#242424",
    "--border-width": "1px",
    "--border-radius": "8px",
    "--border-radius-sm": "4px",
    "--border-radius-lg": "12px",

    "--accent": "#ffffff",
    "--accent-rgb": "255,255,255",
    "--accent-hover": "#e0e0e0",
    "--accent-text": "#0c0c0c",
    "--accent-primary": "#ffffff",

    "--shadow-sm": "0 1px 3px rgba(0,0,0,0.4)",
    "--shadow-md": "0 4px 12px rgba(0,0,0,0.5)",
    "--glow-accent": "0 0 12px rgba(255,255,255,0.15)",
    "--glow-error": "0 0 12px rgba(248,81,73,0.3)",
    "--glow-success": "0 0 12px rgba(63,185,80,0.3)",

    "--color-success": "#3fb950",
    "--color-success-rgb": "63,185,80",
    "--color-error": "#f85149",
    "--color-error-rgb": "248,81,73",
    "--color-warning": "#d29922",
    "--color-warning-rgb": "210,153,34",
    "--color-status-starting": "#5e81ac",
    "--color-status-started": "#8fbc8f",
    "--icon-filter": "invert(1)",
    "--icon-filter-error": "invert(16%) sepia(89%) saturate(4668%) hue-rotate(0deg) brightness(96%) contrast(112%)",

    "--clr-loader-vanilla": "#78909c",
    "--clr-loader-fabric": "#66bb6a",
    "--clr-loader-forge": "#ffa726",
    "--clr-loader-quilt": "#ab47bc",

    "--sidebar-width": "260px",

    "--scrollbar-track": "#0c0c0c",
    "--scrollbar-thumb": "#242424",

    "--font-family": "Cantarell, sans-serif",
    "--font-size-base": "14px",
    "--font-size-sm": "12px",
    "--font-size-lg": "16px"
  }
}
