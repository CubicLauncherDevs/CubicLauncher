#!/usr/bin/env bash
set -euo pipefail

# CubicLauncher Nix Builder
# Equivalente a: makepkg -si (Arch PKGBUILD)
# Clona el repo y compila con Nix

REPO="https://github.com/CubicLauncher/CubicLauncher.git"
BUILD_DIR="cubiclauncher-build"

echo "==> Clonando CubicLauncher..."
if [ -d "$BUILD_DIR" ]; then
  echo "    Actualizando clon existente..."
  cd "$BUILD_DIR"
  git pull --ff-only
  cd ..
else
  git clone --depth 1 "$REPO" "$BUILD_DIR"
fi

echo ""
echo "==> Compilando con Nix..."
cd "$BUILD_DIR"
nix-build dist/nix/release.nix

echo ""
echo "=== Build exitoso ==="
echo "Binario: $(pwd)/result/bin/cubiclauncher"
echo ""
echo "Para instalar:"
echo "  cp $(pwd)/result/bin/cubiclauncher ~/.local/bin/"
echo "  # o agregar result/bin a PATH"
